# CARE clinic reverse proxy — ONE origin, plain HTTP, trusted LAN only.
# Pages and the API share http://care.local, so there is no CORS to configure.
{
	auto_https off
}

:80 {
	encode gzip

	handle /api/* {
		reverse_proxy backend:9000
	}
	handle /admin/* {
		reverse_proxy backend:9000
	}
	handle /static/* {
		reverse_proxy backend:9000
	}
	handle /ping/* {
		reverse_proxy backend:9000
	}
	handle /health/* {
		reverse_proxy backend:9000
	}

	handle {
		reverse_proxy frontend:80
	}
}
