# ============================================================================
# CARE backend settings — the single source of truth for the backend + celery.
# Edit a value here, then `care start` (containers are recreated and re-read
# this file). Nothing else needs editing.
# ============================================================================

# --- Django settings module (our plain-HTTP clinic mode, mounted at /settings) --
DJANGO_SETTINGS_MODULE=clinic_settings
PYTHONPATH=/settings:/app

# --- Database (PostgreSQL) ---------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_DB=care
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@db:5432/care

# --- Redis (cache + Celery queue) -------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# --- Django core ------------------------------------------------------------
# IMPORTANT: `care setup` replaces CHANGE_ME with a random key on first run.
DJANGO_SECRET_KEY=CHANGE_ME
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=["*"]
DJANGO_ADMIN_URL=admin
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=False
# Needed for /admin POSTs over plain http. Add your server IP origin if you use it.
CSRF_TRUSTED_ORIGINS=["http://care.local"]

# --- Object storage (MinIO, S3-compatible) ----------------------------------
# Presigned file URLs the browser hits directly — must be reachable from EVERY
# device (never localhost). Use the server IP if a device can't resolve care.local.
BUCKET_EXTERNAL_ENDPOINT=http://care.local:9100
BUCKET_ENDPOINT=http://minio:9000
BUCKET_REGION=ap-south-1
BUCKET_KEY=minioadmin
BUCKET_SECRET=minioadmin
FILE_UPLOAD_BUCKET=patient-bucket
FACILITY_S3_BUCKET=facility-bucket
# MinIO server root credentials (keep equal to BUCKET_KEY/SECRET above).
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# --- Things the production settings expect (offline-safe placeholders) -------
SNS_ACCESS_KEY=123
SNS_SECRET_KEY=123
EMAIL_HOST=123
EMAIL_USER=123
EMAIL_PASSWORD=123

# --- Backups ----------------------------------------------------------------
# How many days of backups to keep on the Desktop.
DB_BACKUP_RETENTION_PERIOD=14
