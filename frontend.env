# ============================================================================
# CARE frontend settings — baked into the app image at BUILD time (Vite).
# Edit a value here, then `care rebuild-frontend` to apply.
#
# These OVERRIDE care_fe's own committed .env (which supplies logos, locales, etc.),
# so you usually only need the API URL. The app is served at, and calls its API at,
# the same host → same-origin, no CORS.
# ============================================================================

# Backend base URL WITHOUT the /api suffix. MUST be a valid URL (the FE build
# rejects empty). Same host as the app → same-origin.
REACT_CARE_API_URL=http://care.local

# Optional clinic tweaks (uncomment / edit as needed):
# REACT_ALLOWED_LOCALES="en,hi,ta,ml,mr,kn"
# REACT_DEFAULT_COUNTRY=
